<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Entitlements du bundle macOS : la signature Tauri active le hardened
     runtime, qui REFUSE l'accès micro (salons vocaux, appels, test micro,
     messages vocaux) sans cette clé — même autorisation TCC accordée. -->
<plist version="1.0">
<dict>
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
